# ============================================================
# Siplinx AI — auth-service. Скопируй в .env.local и заполни.
# ============================================================

# --- Сервис ---
# Сгенерируй: `openssl rand -base64 32`  (или любой 32+ символьный секрет)
BETTER_AUTH_SECRET=
# Публичный URL сервиса. Локально — как ниже; в проде — https://auth.siplinx.ai
BETTER_AUTH_URL=http://localhost:3210
NEXT_PUBLIC_AUTH_URL=http://localhost:3210

# --- Postgres (Neon / Vercel Postgres / Supabase) ---
DATABASE_URL=postgres://user:password@host:5432/dbname?sslmode=require

# --- Google OAuth (тип клиента: Web application) ---
# Authorized redirect URI в Google Console:
#   http://localhost:3210/api/auth/callback/google   (dev)
#   https://auth.siplinx.ai/api/auth/callback/google  (prod)
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# --- Polar ---
# Organization Access Token (Settings → API Tokens). НЕ публикуй.
POLAR_ACCESS_TOKEN=
# Webhook signing secret (Settings → Webhooks → endpoint .../api/auth/polar/webhooks)
POLAR_WEBHOOK_SECRET=
# sandbox для тестов, production для боевого режима
POLAR_SERVER=sandbox
# ID продуктов подписки (мес/год) из Polar (Products → product → ID)
POLAR_PRODUCT_ID_MONTHLY=
POLAR_PRODUCT_ID_YEARLY=

# --- Безопасность desktop loopback ---
# Десктоп поднимает временный сервер на 127.0.0.1:<порт> для приёма токена.
# Разрешённый диапазон портов (защита от open-redirect).
DESKTOP_LOOPBACK_PORT_MIN=38400
DESKTOP_LOOPBACK_PORT_MAX=38500

# --- CORS (origin десктопа). Для отладки можно "*", в проде сузить. ---
CORS_ALLOW_ORIGIN=*
